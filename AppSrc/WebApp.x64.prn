37851>>>    Procedure SetActionButtons
37854>>>        tWebNavigateData NavigateData
37854>>>        tWebNavigateData NavigateData
37854>>>        Boolean bHasRecord
37854>>>        Handle hoDD
37854>>>
37854>>>        Get Server to hoDD
37855>>>        Get GetNavigateData to NavigateData
37856>>>        Get HasRecord of hoDD to bHasRecord
37857>>>
37857>>>        // let's hide all buttons and then Show the ones we want
37857>>>        WebSet pbRender of oEditBtn to False
37858>>>        WebSet pbRender of oSaveBtn to False
37859>>>        WebSet pbRender of oCancelChangesBtn to False
37860>>>        WebSet pbRender of oDeleteBtn to False
37861>>>
37861>>>        If (NavigateData.bReadOnly) Begin
37863>>>            WebSet pbRender of oEditBtn to True
37864>>>        End
37864>>>>
37864>>>        Else Begin
37865>>>            WebSet pbRender of oSaveBtn to True
37866>>>            WebSet pbRender of oCancelChangesBtn to True
37867>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37868>>>        End
37868>>>>
37868>>>    End_Procedure
37869>>>
37869>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37872>>>        // Close after save
37872>>>        Send NavigateClose Self
37873>>>    End_Procedure
37874>>>
37874>>>    // this will close the view after a delete
37874>>>    Procedure OnViewDeleted Handle hoDDO
37877>>>        Send NavigateClose Self
37878>>>    End_Procedure
