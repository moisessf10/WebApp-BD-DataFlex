38693>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38696>>>        Case Begin
38696>>>            Case (NavigateData.eNavigateType = nfFromMain)
38698>>>                // If from main, this is a propbably a main file Select to Zoom.
38698>>>                String sMsg
38698>>>    
38698>>>                Move (SFormat("From Main%1InvokingObject handle: %2%1Nombre: %3", Character(10), String(hoInvokingObject), String(Name(hoInvokingObject)))) to sMsg
38699>>>                Send ShowInfoBox sMsg
38700>>>                Case Break
38701>>>
38701>>>            Case (NavigateData.eNavigateType = nfFromParent)
38704>>>                // If from parent, this is a constrained drill down.
38704>>>                Case Break
38705>>>
38705>>>            Case (NavigateData.eNavigateType = nfFromChild)
38708>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38708>>>                Case Break
38709>>>
38709>>>            Case Else // must be nfUndefined
38709>>>
38709>>>        Case End
38709>>>
38709>>>        Send SetActionButtons
38710>>>
