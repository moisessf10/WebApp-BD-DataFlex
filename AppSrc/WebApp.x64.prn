38665>>>    Procedure SetActionButtons
38668>>>        tWebNavigateData NavigateData
38668>>>        tWebNavigateData NavigateData
38668>>>        Boolean bHasRecord
38668>>>        Handle hoDD
38668>>>
38668>>>        Get Server to hoDD
38669>>>        Get GetNavigateData to NavigateData
38670>>>        Get HasRecord of hoDD to bHasRecord
38671>>>
38671>>>        // let's hide all buttons and then Show the ones we want
38671>>>        WebSet pbRender of oEditBtn to False
38672>>>        WebSet pbRender of oSaveBtn to False
38673>>>        WebSet pbRender of oCancelChangesBtn to False
38674>>>        WebSet pbRender of oDeleteBtn to False
38675>>>
38675>>>        If (NavigateData.bReadOnly) Begin
38677>>>            WebSet pbRender of oEditBtn to True
38678>>>        End
38678>>>>
38678>>>        Else Begin
38679>>>            WebSet pbRender of oSaveBtn to True
38680>>>            WebSet pbRender of oCancelChangesBtn to True
38681>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38682>>>        End
38682>>>>
38682>>>    End_Procedure
38683>>>
