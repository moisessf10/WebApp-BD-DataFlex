37879>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37882>>>        Case Begin
37882>>>            Case (NavigateData.eNavigateType = nfFromMain)
37884>>>                // If from main, this is a propbably a main file Select to Zoom.
37884>>>                String sMsg
37884>>>    
37884>>>                Move (SFormat("From Main%1InvokingObject handle: %2%1Nombre: %3", Character(10), String(hoInvokingObject), String(Name(hoInvokingObject)))) to sMsg
37885>>>                Send ShowInfoBox sMsg
37886>>>                Case Break
37887>>>
37887>>>            Case (NavigateData.eNavigateType = nfFromParent)
37890>>>                // If from parent, this is a constrained drill down.
37890>>>                Case Break
37891>>>
37891>>>            Case (NavigateData.eNavigateType = nfFromChild)
37894>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37894>>>                Case Break
37895>>>
37895>>>            Case Else // must be nfUndefined
37895>>>
37895>>>        Case End
37895>>>
37895>>>        Send SetActionButtons
37896>>>
37896>>>    End_Procedure
37897>>>
37897>>>End_Object 
